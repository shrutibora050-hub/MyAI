# Root .env.example
# This is a template file. Copy to .env and fill in your actual credentials.
# Each service directory also has its own .env file for service-specific configuration.

# PostgreSQL
POSTGRES_USER=scraper
POSTGRES_PASSWORD=your_secure_postgres_password

# RabbitMQ
RABBITMQ_USER=jobqueue
RABBITMQ_PASSWORD=your_secure_rabbitmq_password

# Important: Never commit .env files to git!
# The .gitignore file should exclude all .env files.
