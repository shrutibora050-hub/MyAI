# RabbitMQ Configuration
# Copy this file to .env and replace with your actual credentials
RABBITMQ_DEFAULT_USER=jobqueue
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password_here

# Connection URLs (update passwords to match above)
RABBITMQ_URL=amqp://jobqueue:your_rabbitmq_password_here@rabbitmq:5672/
DATABASE_URL=postgresql://scraper:your_postgres_password_here@jobs-postgres:5432/jobs_db
